{
  "name": "vcsavibes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VCSAVibes - Complementary platform to VCSA",
  "scripts": {
    "dev": "vite --config vite.config.js",
    "dev:prod": "vite --config vite.config.prod.js",
    "build": "vite build",
    "build:prod": "vite build --config vite.config.prod.js",
    "preview": "vite preview",
    "lint": "eslint src --ext js,jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "start": "npm run dev:prod"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "axios": "^1.15.0",
    "framer-motion": "^12.38.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "vite": "^5.1.0"
  }
}

{
  "apps": [
    {
      "name": "vcsavibes",
      "script": "npm",
      "args": "run dev",
      "cwd": "/rogervibes/vcs/Vcsa-/apps/vcsavibes",
      "instances": 1,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production",
        "PORT": 3002
      },
      "error_file": "/var/log/vcsavibes-error.log",
      "out_file": "/var/log/vcsavibes-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss",
      "merge_logs": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s"
    }
  ]
}

# VCSAVibes Environment Variables

# API Configuration
# For local development, use the Vite proxy (default: /api)
VITE_API_URL=/api

# For production, use the actual backend URL
# VITE_API_URL=https://api.vcsa.com

# Application
VITE_APP_NAME=VCSAVibes
VITE_APP_URL=http://localhost:3001

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_GAMIFICATION=true
VITE_ENABLE_COACHING=true
